# ── Option A: single connection string (cloud / Neon) ──────────────────────────
# Paste the full Neon connection string here (includes host, user, pass, db, ssl).
DATABASE_URL=

# ── Option B: individual vars (local PostgreSQL) ───────────────────────────────
# Leave DATABASE_URL blank and fill these in instead.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gonet_demo_db
DB_USER=postgres
DB_PASS=your_password_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate_a_long_random_string_here

# ── CORS (production only) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set this in Render to your Vercel URL.
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── SamKnows (optional — leave blank to run on seeded demo data only) ──────────
SAMKNOWS_URL=
SAMKNOWS_USER=
SAMKNOWS_PASS=
